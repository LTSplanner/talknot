# === TalKnot 環境変数サンプル ===
# このファイルを .env としてコピーし、各値を設定してください。

# --- アクセス制御 ---
# ログインを許可する Google Workspace のドメイン（カンマ区切りで複数可）
ALLOWED_DOMAINS=yourcompany.com
# 模範トークの登録など管理者操作を許可するメールアドレス（カンマ区切り）
ADMIN_EMAILS=admin@yourcompany.com

# --- Google OAuth (Drive / ログイン) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8501

# --- サービスアカウント / ドメイン全体委任（8アカウント横断アクセス）---
# サービスアカウント鍵(JSON)のパス。未設定なら代理アクセス機能は無効。
GOOGLE_SERVICE_ACCOUNT_FILE=
# 評価対象のメンバー（カンマ区切り）。未設定なら settings.py の既定8名を使用。
TARGET_ACCOUNTS=
# 模範トークの基準アカウント（カンマ区切りで複数可）。
REFERENCE_ACCOUNTS=kkyoya@life-time-support.com,hkumada@life-time-support.com

# --- Gemini API ---
GEMINI_API_KEY=
# 動画解析に対応したモデルを指定（変更可能）
GEMINI_MODEL=gemini-2.5-flash
